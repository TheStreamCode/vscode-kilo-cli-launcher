{
  "name": "vscode-kilo-cli-launcher",
  "displayName": "Kilo CLI Launcher",
  "description": "VS Code extension by Mikesoft that launches a configurable terminal command beside the active editor. Not affiliated with Kilo or KiloCode.",
  "publisher": "mikesoft",
  "version": "0.0.6",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheStreamCode/vscode-kilo-cli-launcher.git"
  },
  "author": {
    "name": "Michael Gasperini",
    "url": "https://mikesoft.it"
  },
  "bugs": {
    "url": "https://github.com/TheStreamCode/vscode-kilo-cli-launcher/issues"
  },
  "homepage": "https://mikesoft.it",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "pricing": "Free",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "vscode",
    "extension",
    "kilo",
    "cli",
    "terminal",
    "launcher",
    "toolbar",
    "editor",
    "command"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kilocodeCliLauncher.openCli",
        "title": "Open Kilo CLI in Side Terminal",
        "category": "KiloCode",
        "icon": {
          "light": "./media/kilo-mark.svg",
          "dark": "./media/kilo-mark.svg"
        }
      },
      {
        "command": "kilocodeCliLauncher.openSettings",
        "title": "Open Kilo CLI Launcher Settings",
        "category": "KiloCode"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "kilocodeCliLauncher.openCli",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "KiloCode CLI Launcher",
      "properties": {
        "kilocodeCliLauncher.cliCommand": {
          "type": "string",
          "default": "kilo",
          "markdownDescription": "Command line used to launch Kilo CLI. The official docs start the TUI with `kilo`; if you installed the npm package and the binary is not on your PATH, you can set this to `npx kilo` or another launch command."
        },
        "kilocodeCliLauncher.terminalName": {
          "type": "string",
          "default": "Kilo CLI",
          "description": "Name of the terminal used by the launcher."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "check": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.86.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
